Bootstrap: docker
From: ubuntu:20.04

%labels
    Maintainer: Hannah Wayment-Steele
    Software: AFNMR + AmberTools

%environment
    export AFNMRHOME=/opt/afnmr
    export AMBERHOME=/opt/miniconda/envs/ambertools/
    export PATH=${AFNMRHOME}/bin:/opt/miniconda/bin:/opt/miniconda/envs/ambertools/bin:$PATH

%post
    set -e

    # Non-interactive apt (prevents tzdata hang)
    export DEBIAN_FRONTEND=noninteractive
    ln -fs /usr/share/zoneinfo/Etc/UTC /etc/localtime
    echo "Etc/UTC" > /etc/timezone

    # HPC / cluster tmp fix
    export TMPDIR=/var/tmp
    mkdir -p /var/tmp
    chmod 1777 /var/tmp

    # Set AFNMRHOME for build
    export AFNMRHOME=/opt/afnmr

    # Update and install dependencies
    apt-get update
    apt-get install -y --no-install-recommends \
        git \
        build-essential \
        gcc \
        gfortran \
        make \
        cmake \
        wget \
        python3 \
        python3-pip \
        libopenblas-dev \
        liblapack-dev \
        bison \
        flex \
        bzip2 \
        curl

    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Install AFNMR
    mkdir -p $AFNMRHOME
    cd $AFNMRHOME
    git clone https://github.com/dacase/afnmr.git .
    make clean || true
    make install
    make test || true

    # --------------------------
    # Install Miniconda
    wget -q https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh -O /tmp/miniconda.sh
    bash /tmp/miniconda.sh -b -p /opt/miniconda
    export PATH=/opt/miniconda/bin:$PATH
    # Accept TOS for non-interactive build
    conda tos accept --override-channels --channel https://repo.anaconda.com/pkgs/main
    conda tos accept --override-channels --channel https://repo.anaconda.com/pkgs/r

    # Install AmberTools (includes cpptraj, tleap, solinprot)
    /opt/miniconda/bin/conda create -y -n ambertools python=3.12 dacase::ambertools-dac=25 --strict-channel-priority -c conda-forge

    export PATH=/opt/miniconda/envs/ambertools/bin:$PATH

%runscript
    # Default entrypoint
    exec "$@"

%help
    AFNMR container with AmberTools installed via conda.
    Usage: afnmr <pdbfile>
    Includes cpptraj, tleap, solinprot, etc.
